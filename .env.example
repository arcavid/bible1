# Public client URL/key. The anon key is safe for browser use, but keep it scoped by Supabase RLS.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only state API. Never expose this value with NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct database URL for migrations/ops; not used by the app runtime.
DATABASE_URL=
DIRECT_URL=
